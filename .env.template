# .env.template - maps environment variable names to Bitwarden vault items.
# Committed to git. Contains NO secrets - only mappings.
#
# Run `./scripts/setup-env.ps1` to generate `.env` from this file.
#
# Syntax:
#   KEY=bw://<folder-path>/<item-name>   Pulled from Bitwarden (password field)
#   KEY=local://prompt                   Prompted on first run, cached in .env.local
#   KEY=<literal>                        Written as-is to .env
#
# Edit this file when the project needs a new secret. Rename example keys
# below, or delete what you don't need.

# --- Shared keys (same key used across all Brandon projects) ----------------
# ANTHROPIC_API_KEY=bw://dev/shared/anthropic-api-key
# NOTION_INTEGRATION_TOKEN=bw://dev/shared/notion-integration-token
# GOOGLE_API_KEY=bw://dev/shared/google-api-key
# OPENROUTER_API_KEY=bw://dev/shared/openrouter-api-key
# OPENAI_API_KEY=bw://dev/shared/openai-api-key

# --- Project-specific keys (per-project Supabase, etc.) ---------------------
# Replace <project-name> with this project's per-project folder name.
# SUPABASE_URL=bw://dev/per-project/<project-name>/supabase-url
# SUPABASE_SERVICE_ROLE_KEY=bw://dev/per-project/<project-name>/supabase-service-role-key

# --- Machine-local values (file paths, etc.) --------------------------------
# DATA_DIR=local://prompt
